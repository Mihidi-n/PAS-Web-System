@{
    ViewData["Title"] = "Home Page";
}

<div class="container mt-5">

   
    <div class="text-center mb-5">
        <h1 class="display-4 fw-bold">Project Approval System</h1>
        <p class="lead text-muted">
            A smart platform for students and supervisors to collaborate through a fair and blind evaluation system.
        </p>

        <div class="mt-4">
            <a asp-area="Identity" asp-page="/Account/Register" class="btn btn-primary btn-lg me-2">
                Get Started
            </a>
            <a asp-area="Identity" asp-page="/Account/Login" class="btn btn-outline-dark btn-lg">
                Login
            </a>
        </div>
    </div>

    
    <div class="row text-center">

        <div class="col-md-4 mb-4">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-body">
                    <h4 class="fw-bold">Submit Proposals</h4>
                    <p class="text-muted">
                        Students can submit project ideas with research areas and technical details easily.
                    </p>
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-4">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-body">
                    <h4 class="fw-bold">Blind Evaluation</h4>
                    <p class="text-muted">
                        Supervisors review proposals without knowing student identity to ensure fairness.
                    </p>
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-4">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-body">
                    <h4 class="fw-bold">Smart Matching</h4>
                    <p class="text-muted">
                        Match students with supervisors based on expertise and interest efficiently.
                    </p>
                </div>
            </div>
        </div>

    </div>

   
    <div class="text-center mt-5">
        <h3 class="fw-bold">Start Your Project Journey Today </h3>
        <a asp-controller="Student" asp-action="Dashboard" class="btn btn-success btn-lg mt-3">
            Go to Dashboard
        </a>
    </div>

</div>